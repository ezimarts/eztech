# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (may contain secrets)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore Terraform plan files
*.tfplan
*.plan

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore lock info if not committing provider versions
# Uncomment if desired
# .terraform.lock.hcl

# Sensitive environment variable files
.env
.env.*

# VS Code settings
.vscode/

# MacOS
.DS_Store

# Logs
*.log

# Terraform plugin cache
plugin-cache/

# Terragrunt cache
.terragrunt-cache/

# Terraform test files
terraform.tfvars
terraform.tfvars.json
ezimarts-web-files
secrets.tfvars
secrets.txt
*.tfvars

